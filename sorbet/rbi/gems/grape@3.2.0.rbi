  def options(*args, **options, &block); end

  # pkg:gem/grape#lib/grape/dsl/routing.rb:183
  def patch(*args, **options, &block); end

  # pkg:gem/grape#lib/grape/dsl/routing.rb:183
  def post(*args, **options, &block); end

  # Define a root URL prefix for your entire API.
