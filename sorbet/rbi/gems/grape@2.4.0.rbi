  # pkg:gem/grape#lib/grape/dsl/settings.rb:73
  def unset_namespace_setting(key); end

  # @param key [Symbol]
  #
  # pkg:gem/grape#lib/grape/dsl/settings.rb:118
  def unset_namespace_stackable(key); end

  # @param key [Symbol]
